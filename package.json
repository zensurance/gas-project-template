{
  "name": "gas-project-template",
  "version": "1.0.0",
  "private": true,
  "description": "Google Apps Script project template with CI/CD, linting, testing, and security scanning",
  "scripts": {
    "lint": "eslint *.gs",
    "lint:fix": "eslint *.gs --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup/gasGlobals.js"
    ],
    "transform": {
      "^.+\\.gs$": "./tests/setup/gsTransform.js"
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleFileExtensions": [
      "js",
      "gs"
    ],
    "collectCoverageFrom": [
      "*.gs"
    ]
  }
}
